---
import { specializedPages, pagePath, homePath } from "../lib/site";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
---

<!-- 買取メニューナビゲーション -->
<section class="py-8 md:py-12 bg-cream">
  <div class="max-w-4xl mx-auto px-4">
    <p class="text-center text-navy font-bold text-sm md:text-base mb-4">
      お探しのサービスをお選びください
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-2 md:gap-3">
      <a
        href={homePath}
        class:list={[
          "flex items-center justify-center gap-1.5 px-3 py-3 md:py-3.5 rounded-xl text-xs md:text-sm font-bold text-center transition-all",
          !currentSlug
            ? "bg-navy text-white shadow-md"
            : "bg-white text-warm-gray border border-cream-dark hover:border-navy/30 hover:shadow-sm"
        ]}
      >
        <span class="text-[10px] opacity-60">▪</span>
        総合トップ
      </a>
      {specializedPages.map((page) => (
        <a
          href={pagePath(page.slug)}
          class:list={[
            "flex items-center justify-center gap-1.5 px-3 py-3 md:py-3.5 rounded-xl text-xs md:text-sm font-bold text-center transition-all",
            currentSlug === page.slug
              ? "bg-navy text-white shadow-md"
              : "bg-white text-warm-gray border border-cream-dark hover:border-navy/30 hover:shadow-sm"
          ]}
        >
          <span class="text-[10px] opacity-60">▪</span>
          {page.shortTitle}
        </a>
      ))}
    </div>
  </div>
</section>
