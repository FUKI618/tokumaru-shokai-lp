---
const nagoyaWards = [
  "千種区", "東区", "北区", "西区", "中村区", "中区",
  "昭和区", "瑞穂区", "熱田区", "中川区", "港区", "南区",
  "守山区", "緑区", "名東区", "天白区",
];

const nearbyAreas = [
  "あま市", "清須市", "北名古屋市", "津島市",
  "愛西市", "弥富市", "東海市", "大府市",
  "刈谷市", "豊明市", "四日市市（三重県）",
];
---

<section id="area" class="py-12 md:py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-bold text-center text-navy mb-4">
      名古屋の対応エリア
    </h2>
    <p class="text-warm-gray text-sm md:text-base mb-8 md:mb-12">
      名古屋市全域を中心に、愛知県近郊エリアまで出張買取に対応
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Nagoya City -->
      <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
        <h3 class="font-bold text-navy text-lg mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          名古屋市全域（16区）
        </h3>
        <div class="flex flex-wrap gap-2">
          {nagoyaWards.map((ward) => (
            <span class="bg-cream text-navy text-sm px-3 py-1.5 rounded-lg font-medium">
              {ward}
            </span>
          ))}
        </div>
      </div>

      <!-- Nearby Areas -->
      <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
        <h3 class="font-bold text-navy text-lg mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
            <path d="M2 12h20"/>
          </svg>
          近郊エリア（愛知県・三重県）
        </h3>
        <div class="flex flex-wrap gap-2">
          {nearbyAreas.map((area) => (
            <span class="bg-cream text-navy text-sm px-3 py-1.5 rounded-lg font-medium">
              {area}
            </span>
          ))}
        </div>
        <p class="text-warm-gray-light text-xs mt-4">
          ※上記以外の愛知県内エリアもご相談ください
        </p>
      </div>
    </div>
  </div>
</section>
