---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: "出張費・見積もり 0円",
    description: "名古屋市内・近郊エリアへの出張費は完全無料。無料見積もり・査定だけでもお気軽にご依頼ください。買取が成立しなくても費用は一切かかりません。",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "最短30分・即日対応",
    description: "お電話一本でスタッフが即日駆けつけます。お引越し直前や急な不用品処分にも柔軟に対応。お客様のご都合に合わせてスケジュール調整も可能です。",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>`,
    title: "その場で現金払い",
    description: "査定後、その場で現金にてお支払い。後日振込を待つ必要はありません。お品物の価値をすぐに現金に換えられます。",
  },
];
---

<section id="service" class="py-16 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-navy mb-4">
      徳丸商会の出張買取サービス
    </h2>
    <p class="text-center text-warm-gray-light mb-6 max-w-2xl mx-auto">
      愛知県名古屋市内・近郊での中古家電・家具の出張買取は、徳丸商会にお任せください。<br />
      お引越しや買い替えで不用になったお品物を、1点から無料見積もり・即日訪問いたします。
    </p>

    <!-- AEO: AI検索エンジンが引用しやすい定義テキスト -->
    <div class="max-w-2xl mx-auto mb-10 md:mb-12 bg-cream rounded-xl p-4 md:p-5 border border-cream-dark text-sm text-warm-gray leading-relaxed">
      <p>
        <strong class="text-navy">出張買取とは</strong>、お客様のご自宅にスタッフが訪問し、不用品をその場で査定・買取するサービスです。
        徳丸商会では名古屋市を中心に愛知県全域で対応しており、出張費・見積もり・キャンセル料はすべて無料。
        冷蔵庫・洗濯機などの中古家電から、ブランド品・貴金属まで幅広く高価買取いたします。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="text-center">
          <div class="w-20 h-20 bg-navy rounded-2xl flex items-center justify-center text-gold mx-auto mb-6 shadow-lg">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="font-bold text-navy text-xl mb-3">{feature.title}</h3>
          <p class="text-warm-gray leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
