---
import { homePath, sectionPath, assetPath } from "../lib/site";
const logoUrl = assetPath("logo.png");
---
<header class="sticky top-0 z-50 bg-navy text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-5 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href={homePath} class="flex items-center gap-2 flex-shrink-0">
      <img src={logoUrl} alt="徳丸商会" width="36" height="36" class="w-9 h-9 object-contain" style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.3));" />
      <span class="text-base font-bold">徳丸商会</span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden xl:flex items-center gap-5 text-[13px] text-white/60">
      <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
      <a href={sectionPath("items")} class="hover:text-white transition-colors">買取品目</a>
      <a href={sectionPath("results")} class="hover:text-white transition-colors">実績</a>
      <a href={sectionPath("area")} class="hover:text-white transition-colors">対応エリア</a>
      <a href={sectionPath("faq")} class="hover:text-white transition-colors">FAQ</a>
    </nav>

    <!-- Right: Hours + CTA -->
    <div class="flex items-center gap-3">
      <p class="hidden lg:block text-xs text-white/40">
        9:00-21:00 年中無休
      </p>
      <a href="tel:052-990-3968" class="flex items-center gap-1.5 text-white/70 hover:text-white text-xs transition-colors" aria-label="電話">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">052-990-3968</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line text-white text-xs font-bold px-3.5 py-1.5 rounded hover:opacity-90 transition-opacity" aria-label="LINE査定">
        LINE査定
      </a>
    </div>
  </div>
</header>
