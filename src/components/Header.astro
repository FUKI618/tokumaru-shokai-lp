---
import { homePath, sectionPath, assetPath } from "../lib/site";
const logoUrl = assetPath("logo.png");
---
<header class="sticky top-0 z-50 bg-navy text-white shadow-lg">
  <div class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between">
    <!-- Logo & Business Name -->
    <a href={homePath} class="flex items-center gap-2.5">
      <img
        src={logoUrl}
        alt="徳丸商会ロゴ"
        width="44"
        height="44"
        class="w-11 h-11 object-contain"
        style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.3));"
      />
      <div class="leading-tight">
        <span class="text-lg font-bold tracking-tight block">徳丸商会</span>
        <span class="text-[10px] text-white/50 tracking-widest hidden sm:block">TOKUMARU SHOKAI</span>
      </div>
    </a>

    <!-- Operating Hours (desktop) -->
    <p class="hidden md:block text-sm text-white/60">
      受付時間 <span class="text-white font-bold">9:00〜21:00</span>（年中無休）
    </p>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-6 text-sm">
      <a href={sectionPath("service")} class="hover:text-gold transition-colors">サービス</a>
      <a href={sectionPath("process")} class="hover:text-gold transition-colors">流れ</a>
      <a href={sectionPath("items")} class="hover:text-gold transition-colors">買取品目</a>
      <a href={sectionPath("results")} class="hover:text-gold transition-colors">実績</a>
      <a href={sectionPath("company")} class="hover:text-gold transition-colors">会社情報</a>
      <a href={sectionPath("area")} class="hover:text-gold transition-colors">対応エリア</a>
      <a href={sectionPath("faq")} class="hover:text-gold transition-colors">よくある質問</a>
    </nav>

    <!-- CTA Buttons -->
    <div class="flex items-center gap-1.5 md:gap-2">
      <!-- Phone: モバイルはアイコンのみ、PCは番号付き -->
      <a
        href="tel:052-990-3968"
        class="flex items-center gap-2 bg-cta hover:bg-cta-light text-white font-bold px-2.5 py-2 md:px-4 rounded-lg transition-colors"
        aria-label="電話でお問い合わせ: 052-990-3968"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="hidden md:inline">052-990-3968</span>
      </a>

      <!-- LINE: モバイルはアイコンのみ、PCはテキスト付き -->
      <a
        href="https://lin.ee/j4wK9IM"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-line hover:opacity-90 text-white font-bold px-2.5 py-2 md:px-4 rounded-lg transition-opacity"
        aria-label="LINEで査定"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        <span class="hidden md:inline">LINE査定</span>
      </a>
    </div>
  </div>
</header>
