---
import { homePath, sectionPath, assetPath } from "../lib/site";
const logoUrl = assetPath("logo.png");
---
<header class="sticky top-0 z-50 bg-navy text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-5 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href={homePath} class="flex items-center gap-2 flex-shrink-0">
      <img src={logoUrl} alt="徳丸商会" width="36" height="36" class="w-9 h-9 object-contain" style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.3));" />
      <span class="text-base font-bold">徳丸商会</span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden xl:flex items-center gap-5 text-[13px] text-white/60">
      <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
      <a href={sectionPath("items")} class="hover:text-white transition-colors">買取品目</a>
      <a href={sectionPath("results")} class="hover:text-white transition-colors">実績</a>
      <a href={sectionPath("area")} class="hover:text-white transition-colors">対応エリア</a>
      <a href={sectionPath("faq")} class="hover:text-white transition-colors">FAQ</a>
    </nav>

    <!-- Right: CTA -->
    <div class="flex items-center gap-2">
      <p class="hidden lg:block text-xs text-white/40 mr-1">
        9:00-21:00 年中無休
      </p>
      <a href="tel:052-990-3968" class="flex items-center gap-1.5 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold text-xs px-3 py-1.5 rounded transition-colors" aria-label="電話">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">052-990-3968</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 bg-line hover:opacity-90 text-white font-bold text-xs px-3 py-1.5 rounded transition-opacity" aria-label="LINE査定">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.629.629 0 0 1-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.63.63 0 0 1 .495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        <span>LINE査定</span>
      </a>
    </div>
  </div>
</header>
