---
const results = [
  {
    name: "冷蔵庫",
    detail: "大型冷蔵庫 500L以上",
    price: "39,000",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="4" y1="10" x2="20" y2="10"/><line x1="10" y1="6" x2="10" y2="6.01"/><line x1="10" y1="14" x2="10" y2="14.01"/></svg>`,
  },
  {
    name: "洗濯機",
    detail: "ドラム式洗濯乾燥機",
    price: "24,500",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="8" y1="6" x2="8" y2="6.01"/><line x1="12" y1="6" x2="16" y2="6"/></svg>`,
  },
  {
    name: "エアコン",
    detail: "ルームエアコン 取外し込み",
    price: "21,000",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="8" rx="2"/><path d="M6 16v2"/><path d="M10 16v4"/><path d="M14 16v2"/><path d="M18 16v4"/></svg>`,
  },
  {
    name: "テレビ",
    detail: "液晶テレビ 55インチ",
    price: "17,000",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
];
---

<section id="results" class="py-16 md:py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-navy mb-4">
      高額買取実績
    </h2>
    <p class="text-center text-warm-gray-light mb-12">
      実際の高価買取事例と相場をご紹介します
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {results.map((item) => (
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark text-center">
          <div class="w-20 h-20 bg-cream rounded-xl flex items-center justify-center text-navy mx-auto mb-4">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-bold text-navy text-lg mb-1">{item.name}</h3>
          <p class="text-warm-gray-light text-xs mb-3">{item.detail}</p>
          <p class="text-cta font-black text-2xl">
            ¥{item.price}<span class="text-sm font-normal text-warm-gray-light">〜</span>
          </p>
        </div>
      ))}
    </div>

    <p class="text-center text-warm-gray-light text-xs mt-6">
      ※買取相場はお品物の状態・年式・メーカーにより異なります。正確な金額は無料見積もりにてお伝えします。
    </p>
  </div>
</section>
