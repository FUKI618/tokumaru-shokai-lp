---
import { faqs } from "../data/faq";
---

<section id="faq" class="py-12 md:py-20 bg-white">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-bold text-center text-navy mb-4">
      よくあるご質問
    </h2>
    <p class="text-warm-gray text-sm mb-8 md:mb-12">
      出張買取や片付けのご相談で、よくいただく内容をまとめています
    </p>

    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <div
          x-data="{ open: false }"
          class="bg-cream rounded-xl border border-cream-dark overflow-hidden"
        >
          <button
            x-on:click="open = !open"
            class="w-full flex items-center justify-between gap-4 p-5 text-left hover:bg-cream-dark transition-colors"
            aria-expanded="false"
            x-bind:aria-expanded="open.toString()"
          >
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 w-7 h-7 bg-navy text-white text-sm font-bold rounded-full flex items-center justify-center mt-0.5">
                Q
              </span>
              <span class="font-bold text-navy">{faq.question}</span>
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-warm-gray flex-shrink-0 transition-transform duration-300"
              x-bind:class="open && 'rotate-180'"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div
            x-show="open"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2"
            class="px-5 pb-5"
            style="display: none;"
          >
            <div class="flex items-start gap-3 pt-2 border-t border-cream-dark">
              <span class="flex-shrink-0 w-7 h-7 bg-gold text-white text-sm font-bold rounded-full flex items-center justify-center mt-0.5">
                A
              </span>
              <p class="text-warm-gray leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
