---
---
<section class="relative bg-navy text-white overflow-hidden">

  <div class="relative max-w-6xl mx-auto px-5 py-10 md:py-24 text-center">
    <!-- Urgency Badge -->
    <div class="inline-flex items-center gap-2 bg-gold/15 border border-gold/30 text-gold-light rounded-full px-4 py-1.5 text-xs md:text-sm font-bold mb-5 md:mb-6 animate-pulse-slow">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-gold-light"></span>
      </span>
      買取強化中 ― お早めにご相談を
    </div>

    <!-- H1 -->
    <h1 class="font-black mb-5 md:mb-8">
      <span class="block text-base md:text-xl lg:text-2xl text-white/70 font-bold mb-2 md:mb-3">名古屋の出張買取・不用品回収なら</span>
      <span class="block text-gold text-3xl md:text-6xl lg:text-7xl leading-none">徳丸商会</span>
    </h1>

    <p class="text-sm md:text-lg text-white/60 mb-6 md:mb-10 max-w-xl mx-auto leading-relaxed text-left">
      家電・家具・ブランド品の出張買取から、不用品回収・遺品整理まで。愛知県名古屋市を中心に即日対応いたします。
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row justify-center gap-2.5 md:gap-4 mb-3 md:mb-6 px-2 sm:px-0">
      <a
        href="https://lin.ee/j4wK9IM"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-line hover:brightness-110 text-white font-bold text-[0.95rem] md:text-lg px-5 md:px-8 py-3 md:py-4 rounded-xl shadow-lg transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        <span>写真を送って無料査定</span>
      </a>
      <a
        href="tel:052-990-3968"
        class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-light text-white font-bold text-[0.95rem] md:text-lg px-5 md:px-8 py-3 md:py-4 rounded-xl shadow-lg transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>電話で相談 052-990-3968</span>
      </a>
    </div>

    <p class="text-xs text-white/50 mb-5 md:hidden">
      LINEなら写真を送るだけ。お電話なら訪問相談へ。
    </p>

    <!-- Social Proof Counters -->
    <div class="flex justify-center gap-4 md:gap-10 mb-5 md:mb-10">
      <div class="text-center">
        <p class="text-xl md:text-4xl font-black text-gold">1,200<span class="text-xs md:text-lg">件</span></p>
        <p class="text-xs text-white/50 mt-1">累計買取実績</p>
      </div>
      <div class="w-px bg-white/20"></div>
      <div class="text-center">
        <p class="text-xl md:text-4xl font-black text-gold">98<span class="text-xs md:text-lg">%</span></p>
        <p class="text-xs text-white/50 mt-1">お客様満足度</p>
      </div>
      <div class="w-px bg-white/20"></div>
      <div class="text-center">
        <p class="text-xl md:text-4xl font-black text-gold">0<span class="text-xs md:text-lg">円</span></p>
        <p class="text-xs text-white/50 mt-1">出張費・査定費</p>
      </div>
    </div>

    <p class="text-xs md:text-xs text-white/45 mb-5 md:mb-8">
      ※2026年4月時点の累計対応実績・自社集計値をもとに掲載しています。
    </p>

    <!-- USP Badges -->
    <div class="flex flex-col sm:flex-row sm:flex-wrap justify-center items-center gap-2 md:gap-4 mb-5 md:mb-10">
      <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 md:px-5 md:py-2.5 border border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5 text-gold flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span class="font-bold text-xs md:text-base">最短30分で訪問</span>
      </div>
      <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 md:px-5 md:py-2.5 border border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5 text-gold flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        <span class="font-bold text-xs md:text-base">出張費・査定費 0円</span>
      </div>
      <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 md:px-5 md:py-2.5 border border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5 text-gold flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="6" width="20" height="12" rx="2"/>
          <path d="M12 12h.01"/>
          <path d="M17 12h.01"/>
          <path d="M7 12h.01"/>
        </svg>
        <span class="font-bold text-xs md:text-base">その場で現金払い</span>
      </div>
    </div>

    <!-- Friction reducers -->
    <div class="flex justify-center gap-3 md:gap-4 text-xs md:text-xs text-white/60 mb-3">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-cta flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        営業なし
      </span>
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-cta flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        査定だけOK
      </span>
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-cta flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        キャンセル0円
      </span>
    </div>

    <!-- Trust info -->
    <p class="text-xs md:text-sm text-white/50">
      受付時間 9:00〜21:00（年中無休）
    </p>
  </div>
</section>
