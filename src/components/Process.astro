---
const steps = [
  {
    number: "01",
    title: "お電話・LINEで連絡",
    description: "買取希望のお品物や訪問のご希望日時をお伝えください。LINEなら写真を送るだけで事前査定も可能です。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
  {
    number: "02",
    title: "ご訪問・査定・現金払い",
    description: "スタッフがご自宅にお伺いし、お品物を丁寧に査定。金額にご納得いただければ、その場で現金をお渡しします。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    number: "03",
    title: "お品物の運び出し",
    description: "重い家電や大型家具もスタッフが搬出。お部屋の養生も丁寧に行い、傷をつけずにお運びします。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  },
];
---

<section id="process" class="py-12 md:py-20 bg-cream">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-bold text-center text-navy mb-4">
      ご依頼の流れ
    </h2>
    <p class="text-warm-gray text-sm md:text-base mb-8 md:mb-12">
      かんたん3ステップで完了します
    </p>

    <div class="space-y-5 md:space-y-8">
      {steps.map((step, index) => (
        <div class="flex gap-4 md:gap-6 items-start">
          {/* Step Number Circle */}
          <div class="flex-shrink-0">
            <div class="w-12 h-12 md:w-16 md:h-16 bg-navy rounded-full flex items-center justify-center text-gold shadow-lg">
              <Fragment set:html={step.icon} />
            </div>
            {index < steps.length - 1 && (
              <div class="w-0.5 h-8 bg-navy/20 mx-auto mt-2" />
            )}
          </div>

          {/* Content */}
          <div class="bg-white rounded-xl p-5 shadow-sm border border-cream-dark flex-1">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-bold text-gold bg-gold/10 px-2.5 py-0.5 rounded-full whitespace-nowrap">
                STEP {step.number}
              </span>
              <h3 class="font-bold text-navy text-sm md:text-lg">{step.title}</h3>
            </div>
            <p class="text-warm-gray text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
