---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import PainPoints from "../components/PainPoints.astro";
import Urgency from "../components/Urgency.astro";
import Service from "../components/Service.astro";
import Process from "../components/Process.astro";
import CTASection from "../components/CTASection.astro";
import Items from "../components/Items.astro";
import Results from "../components/Results.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import Testimonials from "../components/Testimonials.astro";
import Area from "../components/Area.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
---

<Layout
  title="名古屋の出張買取なら徳丸商会｜家電・家具を高額買取・出張費無料"
  description="名古屋市・近郊エリアの出張買取は徳丸商会へ。家電・家具・ブランド品をその場で現金買取。出張費・査定費0円、最短30分で訪問。052-990-3968"
>
  <Header />
  <main>
    <Hero />
    <PainPoints />
    <Urgency />
    <Service />
    <Process />
    <CTASection id="cta-mid" variant="mid" />
    <Items />
    <Results />
    <BeforeAfter />
    <Testimonials />
    <Area />
    <FAQ />
    <CTASection id="contact" variant="bottom" />
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
