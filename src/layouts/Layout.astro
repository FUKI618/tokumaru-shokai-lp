---
interface Props {
  title: string;
  description: string;
  includeTopSchemas?: boolean;
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";
import ScrollToTop from "../components/ScrollToTop.astro";
import { company } from "../data/company";

const { title, description, includeTopSchemas = false } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.png"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
const isGitHubPages = siteUrl.hostname === "fuki618.github.io";
const robots = isGitHubPages ? "noindex, nofollow, max-image-preview:large" : "index, follow, max-image-preview:large";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会の出張買取LP。名古屋の家電・家具買取、出張費無料。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋の出張買取" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会の出張買取LP。名古屋の家電・家具買取、出張費無料。" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- GTMはbody末尾に配置（headのCSS読み込みをブロックしないため） -->
  </head>
  <body class="antialiased">
    <ScrollToTop />

    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W493L98W"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Alpine.js -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();

      // smoothスクロールはページ完全読み込み後に有効化（スクロールジャンプ防止）
      window.addEventListener('load', () => {
        setTimeout(() => {
          document.documentElement.classList.add('loaded');
        }, 500);
      });
    </script>

    <!-- Google Tag Manager (body末尾配置: headのCSS読み込みをブロックしない) -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-W493L98W');
    </script>

    <!-- JSON-LD: body末尾に配置（headのCSS読み込みをブロックしないため） -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${homeUrl}#localbusiness`,
      "name": company.name,
      "description": "名古屋市中区を拠点に、出張買取・不用品回収・遺品整理・残置物撤去に対応しています。出張費・見積もり・査定費は無料です。",
      "telephone": company.phone,
      "url": homeUrl,
      "image": ogImage,
      "priceRange": "$$",
      "openingHours": "Mo-Su 09:00-21:00",
      "address": { "@type": "PostalAddress", "addressLocality": "名古屋市中区", "addressRegion": "愛知県", "addressCountry": "JP" },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        { "@type": "City", "name": "あま市" }, { "@type": "City", "name": "清須市" },
        { "@type": "City", "name": "北名古屋市" }, { "@type": "City", "name": "津島市" },
        { "@type": "City", "name": "愛西市" }, { "@type": "City", "name": "弥富市" },
        { "@type": "City", "name": "東海市" }, { "@type": "City", "name": "大府市" },
        { "@type": "City", "name": "刈谷市" }, { "@type": "City", "name": "豊明市" },
        { "@type": "City", "name": "四日市市", "containedInPlace": { "@type": "State", "name": "三重県" } }
      ],
      "sameAs": [company.lineUrl, company.sourceUrl],
      "hasOfferCatalog": {
        "@type": "OfferCatalog", "name": "出張買取・片付けサービス",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "家電出張買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "家具出張買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド品・貴金属買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "不用品回収" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "遺品整理" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "残置物撤去" } }
        ]
      }
    })} />
    {includeTopSchemas && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org", "@type": "HowTo",
          "name": "名古屋で出張買取を依頼する方法",
          "description": "徳丸商会の出張買取サービスを利用する手順です。",
          "totalTime": "PT1H",
          "estimatedCost": { "@type": "MonetaryAmount", "currency": "JPY", "value": "0" },
          "step": [
            { "@type": "HowToStep", "position": 1, "name": "お電話・LINEでお問い合わせ", "text": `買取希望のお品物や訪問日時をお伝えください。${company.phone}まで。` },
            { "@type": "HowToStep", "position": 2, "name": "ご訪問・査定・現金払い", "text": "スタッフがご自宅にお伺いし、お品物を丁寧に査定。その場で現金をお渡しします。" },
            { "@type": "HowToStep", "position": 3, "name": "お品物の運び出し", "text": "重い家電や大型家具もスタッフが搬出します。" }
          ]
        })} />
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org", "@type": "WebPage",
          "name": title, "description": description, "url": canonicalUrl, "inLanguage": "ja",
          "about": { "@id": `${homeUrl}#localbusiness` },
          "primaryImageOfPage": { "@type": "ImageObject", "url": ogImage }
        })} />
      </>
    )}
  </body>
</html>
