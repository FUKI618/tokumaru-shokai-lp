---
interface Props {
  title: string;
  description: string;
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";

const { title, description } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.png"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会の出張買取LP。名古屋の家電・家具買取、出張費無料。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋の出張買取" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会の出張買取LP。名古屋の家電・家具買取、出張費無料。" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-W493L98W');
    </script>

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${homeUrl}#localbusiness`,
      "name": "徳丸商会",
      "description": "名古屋市・近郊エリアの出張買取サービス。家電・家具・ブランド品をその場で現金買取。出張費・査定費0円。",
      "telephone": "052-990-3968",
      "url": homeUrl,
      "image": ogImage,
      "priceRange": "$$",
      "openingHours": "Mo-Su 09:00-21:00",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "名古屋市",
        "addressRegion": "愛知県",
        "addressCountry": "JP"
      },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        { "@type": "City", "name": "あま市" },
        { "@type": "City", "name": "清須市" },
        { "@type": "City", "name": "北名古屋市" },
        { "@type": "City", "name": "津島市" },
        { "@type": "City", "name": "愛西市" },
        { "@type": "City", "name": "弥富市" },
        { "@type": "City", "name": "東海市" },
        { "@type": "City", "name": "大府市" },
        { "@type": "City", "name": "刈谷市" },
        { "@type": "City", "name": "豊明市" },
        { "@type": "City", "name": "四日市市", "containedInPlace": { "@type": "State", "name": "三重県" } }
      ],
      "sameAs": ["https://lin.ee/j4wK9IM"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "出張買取サービス",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "家電出張買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "家具出張買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド品・貴金属買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "不用品まとめて回収" } }
        ]
      }
    })} />

    <!-- JSON-LD: FAQPage (src/data/faq.ts から自動生成) -->
    <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W493L98W"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Alpine.js -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
